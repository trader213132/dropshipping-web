# =============================================================================
# CommerceForge AI — Environment Variables
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="CommerceForge AI"

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# With Docker Compose: postgresql://commerceforge:commerceforge_dev@localhost:5432/commerceforge_dev
# With cloud provider: your connection string here
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://commerceforge:commerceforge_dev@localhost:5432/commerceforge_dev?schema=public"

# For connection pooling in production (e.g., PgBouncer, Supabase pooler)
# DATABASE_URL_UNPOOLED=""

# -----------------------------------------------------------------------------
# Redis
# With Docker Compose: redis://:redis_dev_password@localhost:6379
# -----------------------------------------------------------------------------
REDIS_URL="redis://:redis_dev_password@localhost:6379"

# -----------------------------------------------------------------------------
# Authentication (Auth.js / NextAuth)
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET="REPLACE_WITH_RANDOM_SECRET_32_CHARS_MIN"
AUTH_URL="http://localhost:3000"

# OAuth Providers (optional — configure in Phase 1)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# -----------------------------------------------------------------------------
# Stripe (Phase 12)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# AI Provider
# When set, brand generation and product analysis use claude-sonnet-4-6.
# Without it, a deterministic demo algorithm is used (no API calls needed).
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=""

# -----------------------------------------------------------------------------
# Object Storage (Phase 6+)
# Local dev uses filesystem; production needs real provider
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# STORAGE_S3_BUCKET=""
# STORAGE_S3_REGION=""
# STORAGE_S3_ACCESS_KEY_ID=""
# STORAGE_S3_SECRET_ACCESS_KEY=""

# -----------------------------------------------------------------------------
# Shopify (Phase 9)
# -----------------------------------------------------------------------------
# SHOPIFY_CLIENT_ID=""
# SHOPIFY_CLIENT_SECRET=""
# SHOPIFY_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Email (Phase 1+)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@commerceforge.ai"

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_FLAG_STORE_BUILDER=true
FEATURE_FLAG_AI_GENERATION=false
FEATURE_FLAG_SHOPIFY_INTEGRATION=false
FEATURE_FLAG_BILLING=false

# -----------------------------------------------------------------------------
# Logging
# Values: fatal, error, warn, info, debug, trace, silent
# -----------------------------------------------------------------------------
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# Admin access
# Comma-separated emails that can access /admin (feature flags + audit logs).
# -----------------------------------------------------------------------------
# ADMIN_EMAILS="you@example.com"

# -----------------------------------------------------------------------------
# Demo / Seed Mode
# Set to true to enable demo data and skip live integrations.
# Seed the DB with: pnpm db:seed (creates demo@commerceforge.ai / Demo1234!)
# -----------------------------------------------------------------------------
DEMO_MODE=true
